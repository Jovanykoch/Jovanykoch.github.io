# Quantumult X RuleSet - Hijacking.list (Pure Rules)
# Repo: Jovanykoch/Jovanykoch.github.io
# Updated: 2026-04-03
#
# Notes:
# - This file contains ONLY rules (no trailing policy like ",REJECT").
# - In your .conf use:
#   [filter_remote]
#   https://<your-domain>/qx/Hijacking.list, tag=Hijacking, force-policy=reject, update-interval=86400, opt-parser=false, enabled=true
#
# --- Known hijacking / phishing domains
host-suffix,10010.com.uelink.com.cn
host-suffix,114so.cn
host-suffix,2345.com
host-suffix,hao123.net
host-suffix,hao2.com

# --- ISP DNS hijack endpoints (common CN ISP redirect domains)
host-suffix,wap.cmwap.com

# --- Malware / stalkerware C2
host-suffix,mobogenie.com
host-suffix,vdpsp.com
host-suffix,adbantuan.com