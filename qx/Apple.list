# Quantumult X RuleSet - Apple.list (host-suffix / host)
# Repo: Jovanykoch/Jovanykoch.github.io
# Updated: 2026-04-03
#
# Usage (Quantumult X):
# [filter_remote]
# https://jkoch14.me/qx/Apple.list, tag=Apple.list, force-policy=DIRECT, update-interval=86400, opt-parser=false, enabled=true
#
# Strict:
# - Apple-owned domains only (avoid shared CDN domains)

# --- Primary Apple domains ---
host-suffix,apple.com
host-suffix,apple.com.cn
host-suffix,apple.co
host-suffix,aaplimg.com

# --- Apple ID / Accounts / Auth ---
host,appleid.apple.com
host,idmsa.apple.com
host,gsa.apple.com

# --- iCloud / Cloud ---
host-suffix,icloud.com
host-suffix,icloud-content.com
host-suffix,me.com
host-suffix,mac.com
host,setup.icloud.com
host-suffix,apzones.com
host-suffix,apple-cloudkit.com
host,cloud.apple.com

# --- Push Notifications (APNs) ---
host-suffix,push.apple.com
host,courier.push.apple.com

# --- App Store / iTunes / Media ---
host,apps.apple.com
host-suffix,itunes.com
host,itunes.apple.com
host-suffix,mzstatic.com
host-suffix,appstore.com

# --- Music / TV / Podcasts / Books ---
host,music.apple.com
host,tv.apple.com
host,podcasts.apple.com
host,books.apple.com

# --- Siri / Location / Maps / Device services (common endpoints) ---
host,siri.apple.com
host,ls.apple.com
host,gs-loc.apple.com

# --- Software Update / Activation / Enrollment ---
host,swcdn.apple.com
host,swdownload.apple.com
host,swscan.apple.com
host,mesu.apple.com
host,oscdn.apple.com
host,osrecovery.apple.com
host,albert.apple.com
host,deviceenrollment.apple.com

# --- Apple News (optional) ---
host-suffix,apple.news

# --- Apple Developer (optional) ---
host,developer.apple.com
host,devimages-cdn.apple.com
host,download.developer.apple.com