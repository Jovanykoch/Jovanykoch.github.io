# === Local Area Network (Optimized) ===

# Router / Local domains
HOST,router.asus.com,LocalAreaNetwork
HOST,routerlogin.com,LocalAreaNetwork
HOST,www.asusrouter.com,LocalAreaNetwork

HOST-SUFFIX,local,LocalAreaNetwork
HOST-SUFFIX,localhost,LocalAreaNetwork
HOST-SUFFIX,lan,LocalAreaNetwork
HOST-SUFFIX,home,LocalAreaNetwork
HOST-SUFFIX,router,LocalAreaNetwork

HOST-SUFFIX,miwifi.com,LocalAreaNetwork
HOST-SUFFIX,tplogin.cn,LocalAreaNetwork
HOST-SUFFIX,tendawifi.com,LocalAreaNetwork

# IPv4 private ranges
IP-CIDR,10.0.0.0/8,LocalAreaNetwork,no-resolve
IP-CIDR,172.16.0.0/12,LocalAreaNetwork,no-resolve
IP-CIDR,192.168.0.0/16,LocalAreaNetwork,no-resolve
IP-CIDR,127.0.0.0/8,LocalAreaNetwork,no-resolve
IP-CIDR,169.254.0.0/16,LocalAreaNetwork,no-resolve
IP-CIDR,100.64.0.0/10,LocalAreaNetwork,no-resolve
IP-CIDR,198.18.0.0/16,LocalAreaNetwork,no-resolve
IP-CIDR,224.0.0.0/4,LocalAreaNetwork,no-resolve

# IPv6 ranges
IP6-CIDR,::1/128,LocalAreaNetwork,no-resolve
IP6-CIDR,fc00::/7,LocalAreaNetwork,no-resolve
IP6-CIDR,fe80::/10,LocalAreaNetwork,no-resolve