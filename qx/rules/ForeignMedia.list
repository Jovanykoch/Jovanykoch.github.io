# ForeignMedia.list (Quantumult X Pure Rules)
# International streaming services
# Updated: 2026-04-03
#
# Usage (Quantumult X):
# [filter_remote]
# https://<your-domain>/qx/ForeignMedia.list, tag=ForeignMedia, force-policy=Proxy, update-interval=86400, opt-parser=false, enabled=true
#
# Notes:
# - This file contains ONLY rules (no trailing ",PROXY").
# - Policy is controlled by force-policy in your .conf.

# Netflix
host-suffix,netflix.com
host-suffix,nflxvideo.net
host-suffix,nflximg.net
host-suffix,nflxso.net

# YouTube
host-suffix,youtube.com
host-suffix,googlevideo.com
host-suffix,ytimg.com

# Disney+
host-suffix,disneyplus.com
host-suffix,dssott.com
host-suffix,bamgrid.com

# Spotify
host-suffix,spotify.com
host-suffix,scdn.co
host-suffix,spotifycdn.com

