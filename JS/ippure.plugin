#!name=IP-Pure
#!desc=节点 IP 纯净度检测（IPPure）通过IPPure接口检测IP质量。需设定 select 类型代理策略组，必须先手动点击选中所需测试节点，再长按节点选择 IPPure 测试。
#!date=2026-01-21
#!category=🐹 BOBO面板模块
#!author=StashNetworks[https://github.com/StashNetworks],sooyaaabo[https://github.com/sooyaaabo]
#!openUrl=https://ippure.com/

[Rule]
DOMAIN-SUFFIX,ippure.com,PROXY

[Script]
generic script-path=https://raw.githubusercontent.com/Jovanykoch/Jovanykoch.github.io/main/loon/module/ippure.js, timeout=10, tag=IPPure, img-url=leaf