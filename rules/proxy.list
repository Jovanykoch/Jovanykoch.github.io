# Surge 5 RULE-SET (DOMAIN-SUFFIX rules)
# Target Policy: US
# Includes:
#   - Swiftgram/Telegram
#   - X (Twitter)
#   - OpenAI (ChatGPT/API)
#   - Spotify
#   - Meta (FB/IG/WhatsApp/Messenger + CDNs)
#   - PayPal
# Plus a few common extras (Discord/Reddit/Wikipedia).
#
# Usage (Surge):
#   [Rule]
#   RULE-SET,https://your-domain-or-raw-link/proxy.list,Proxy
#
# Recommended order:
#   RULE-SET,allow.list,DIRECT
#   RULE-SET,reject.list,REJECT
#   RULE-SET,apple.list,DIRECT
#   RULE-SET,github.list,Proxy
#   RULE-SET,proxy.list,Proxy
#   RULE-SET,china.list,DIRECT
#   GEOIP,CN,DIRECT
#   FINAL,Proxy

# -----------------------
# Telegram / Swiftgram
# -----------------------
DOMAIN-SUFFIX,telegram.org
DOMAIN-SUFFIX,t.me
DOMAIN-SUFFIX,tdesktop.com
DOMAIN-SUFFIX,telegra.ph
DOMAIN-SUFFIX,telegram.me
DOMAIN-SUFFIX,telegram.dog
DOMAIN-SUFFIX,telesco.pe

# -----------------------
# X (Twitter)
# -----------------------
DOMAIN-SUFFIX,x.com
DOMAIN-SUFFIX,twitter.com
DOMAIN-SUFFIX,t.co
DOMAIN-SUFFIX,twimg.com

# -----------------------
# OpenAI / ChatGPT
# -----------------------
DOMAIN-SUFFIX,openai.com
DOMAIN-SUFFIX,chatgpt.com
DOMAIN-SUFFIX,oaistatic.com
DOMAIN-SUFFIX,oaiusercontent.com
# Auth flows sometimes traverse this (broad; remove if you don't want it proxied)
DOMAIN-SUFFIX,auth0.com

# -----------------------
# Spotify
# -----------------------
DOMAIN-SUFFIX,spotify.com
DOMAIN-SUFFIX,spotifycdn.com
DOMAIN-SUFFIX,scdn.co
DOMAIN-SUFFIX,spoti.fi
DOMAIN-SUFFIX,spotifycharts.com
DOMAIN-SUFFIX,spotifyforbrands.com

# -----------------------
# Meta (Instagram )
# -----------------------
DOMAIN-SUFFIX,cdninstagram.com
DOMAIN-SUFFIX,instagram.com

# -----------------------
# PayPal
# -----------------------
DOMAIN-SUFFIX,paypal.com
DOMAIN-SUFFIX,paypalobjects.com
DOMAIN-SUFFIX,pypl.com

# -----------------------
# Common extras
# -----------------------
DOMAIN-SUFFIX,discord.com
DOMAIN-SUFFIX,discord.gg
DOMAIN-SUFFIX,discordapp.com
DOMAIN-SUFFIX,discordapp.net
DOMAIN-SUFFIX,reddit.com
DOMAIN-SUFFIX,redd.it
DOMAIN-SUFFIX,wikipedia.org
DOMAIN-SUFFIX,wikimedia.org

# Google
DOMAIN-SUFFIX,google.com
DOMAIN-SUFFIX,googleapis.com
DOMAIN-SUFFIX,gstatic.com
DOMAIN-SUFFIX,youtube.com
DOMAIN-SUFFIX,youtu.be
DOMAIN-SUFFIX,googlevideo.com
