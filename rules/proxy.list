# Surge 5 RULE-SET (DOMAIN-SUFFIX rules)
# Target Policy: Proxy
# Includes:
#   - Swiftgram/Telegram
#   - Microsoft (Full list merged)
#   - Education (Merged)
#   - X (Twitter)
#   - OpenAI (ChatGPT/API)
#   - Spotify
#   - Meta (FB/IG/WhatsApp/Messenger + CDNs)
#   - PayPal
#   - GitHub (all services)
# Plus a few common extras (Discord/Reddit/Wikipedia).
#
# Usage (Surge):
#   [Rule]
#   RULE-SET,https://your-domain-or-raw-link/proxy.list,Proxy
#
# Recommended order:
#   RULE-SET,allow.list,DIRECT
#   RULE-SET,reject.list,REJECT
#   RULE-SET,apple.list,DIRECT
#   RULE-SET,proxy.list,Proxy
#   RULE-SET,china.list,DIRECT
#   GEOIP,CN,DIRECT
#   FINAL,Proxy

# -----------------------
# Telegram / Swiftgram
# -----------------------
DOMAIN-SUFFIX,swiftgram.app
DOMAIN-SUFFIX,swiftgram.org
DOMAIN-SUFFIX,swiftgram.net
DOMAIN-SUFFIX,swiftgram.pro    # TODO verify ownership
DOMAIN-SUFFIX,telegram.org
