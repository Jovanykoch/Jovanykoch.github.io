# LAN / Local / Private (Optimized for Surge iOS)

# -----------------------
# Router / Gateway Access
# -----------------------
DOMAIN,asusrouter.com
DOMAIN,router.asus.com
DOMAIN,routerlogin.com
DOMAIN,routerlogin.net
DOMAIN,tplinkwifi.net

# -----------------------
# Local Discovery
# -----------------------
DOMAIN-SUFFIX,local
DOMAIN-SUFFIX,home.arpa
DOMAIN-SUFFIX,localdomain
DOMAIN-SUFFIX,lan

# -----------------------
# Reverse DNS
# -----------------------
DOMAIN-SUFFIX,in-addr.arpa
DOMAIN-SUFFIX,ip6.arpa

# -----------------------
# IPv4 Private (核心必备)
# -----------------------
IP-CIDR,10.0.0.0/8,no-resolve
IP-CIDR,172.16.0.0/12,no-resolve
IP-CIDR,192.168.0.0/16,no-resolve

# -----------------------
# Carrier NAT（移动网络关键）
# -----------------------
IP-CIDR,100.64.0.0/10,no-resolve

# -----------------------
# Loopback / Link-local
# -----------------------
IP-CIDR,127.0.0.0/8,no-resolve
IP-CIDR,169.254.0.0/16,no-resolve

# -----------------------
# Multicast / Reserved（保留最关键）
# -----------------------
IP-CIDR,224.0.0.0/4,no-resolve

# -----------------------
# IPv6（仅保留必要）
# -----------------------
IP-CIDR6,::1/128,no-resolve
IP-CIDR6,fc00::/7,no-resolve
IP-CIDR6,fe80::/10,no-resolve
