# Surge 5 RULE-SET (DOMAIN-SUFFIX rules) - STRICT
# Target Policy: DIRECT
# Device: iOS (Surge 5.17.1)
#
# Usage:
#   [Rule]
#   RULE-SET,https://your-domain-or-raw-link/apple.list,DIRECT
#
# Strict mode rules:
# - Apple-owned domains only (no Akamai / shared CDN domains).
# - Minimizes overmatching unrelated traffic.

# --- Primary Apple domains ---
DOMAIN-SUFFIX,apple.com
DOMAIN-SUFFIX,apple.com.cn
DOMAIN-SUFFIX,apple.co
DOMAIN-SUFFIX,aaplimg.com

# --- Apple ID / Accounts / Auth ---
DOMAIN-SUFFIX,appleid.apple.com
DOMAIN-SUFFIX,idmsa.apple.com
DOMAIN-SUFFIX,gsa.apple.com

# --- iCloud / Cloud ---
DOMAIN-SUFFIX,icloud.com
DOMAIN-SUFFIX,icloud-content.com
DOMAIN-SUFFIX,me.com
DOMAIN-SUFFIX,mac.com
DOMAIN-SUFFIX,setup.icloud.com
DOMAIN-SUFFIX,apzones.com
DOMAIN-SUFFIX,apple-cloudkit.com
DOMAIN-SUFFIX,cloud.apple.com

# --- Push Notifications (APNs) ---
DOMAIN-SUFFIX,push.apple.com
DOMAIN-SUFFIX,courier.push.apple.com

# --- App Store / iTunes / Media ---
DOMAIN-SUFFIX,apps.apple.com
DOMAIN-SUFFIX,itunes.com
DOMAIN-SUFFIX,itunes.apple.com
DOMAIN-SUFFIX,mzstatic.com
DOMAIN-SUFFIX,appstore.com

# --- Music / TV / Podcasts / Books ---
DOMAIN-SUFFIX,music.apple.com
DOMAIN-SUFFIX,tv.apple.com
DOMAIN-SUFFIX,podcasts.apple.com
DOMAIN-SUFFIX,books.apple.com

# --- Siri / Location / Maps / Device services (common endpoints) ---
DOMAIN-SUFFIX,siri.apple.com
DOMAIN-SUFFIX,ls.apple.com
DOMAIN-SUFFIX,gs-loc.apple.com

# --- Software Update / Activation / Enrollment ---
DOMAIN-SUFFIX,swcdn.apple.com
DOMAIN-SUFFIX,swdownload.apple.com
DOMAIN-SUFFIX,swscan.apple.com
DOMAIN-SUFFIX,mesu.apple.com
DOMAIN-SUFFIX,oscdn.apple.com
DOMAIN-SUFFIX,osrecovery.apple.com
DOMAIN-SUFFIX,albert.apple.com
DOMAIN-SUFFIX,deviceenrollment.apple.com

# --- Apple Pay ---
DOMAIN-SUFFIX,apple-pay-gateway.apple.com
DOMAIN-SUFFIX,cdn-apple-static.net # TODO verify ownership

# --- Apple News (optional) ---
DOMAIN-SUFFIX,apple.news

# --- Apple Developer (optional, still Apple-owned) ---
DOMAIN-SUFFIX,developer.apple.com
DOMAIN-SUFFIX,devimages-cdn.apple.com
DOMAIN-SUFFIX,download.developer.apple.com
