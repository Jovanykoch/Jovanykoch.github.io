# Surge RULE-SET
# Name: httpdns-block
# Action (recommended): REJECT
# Purpose:
# - Block HTTPDNS / HTTPSDNS endpoints to reduce DNS hijack / app-level DNS bypass.
# Notes:
# - Enabling this may affect some CN apps' connectivity/latency (they may rely on HTTPDNS).
# - Recommended to keep this as an optional switchable ruleset in Surge.

# Common patterns
DOMAIN-KEYWORD,httpsdns
DOMAIN-KEYWORD,https-dns
DOMAIN-KEYWORD,https.dns
DOMAIN-KEYWORD,httpdns
DOMAIN-KEYWORD,http-dns
DOMAIN-KEYWORD,http.dns

# CDN/DNS variants
DOMAIN-KEYWORD,cdndns
DOMAIN-KEYWORD,cdn-dns
DOMAIN-KEYWORD,cdn.dns
DOMAIN-KEYWORD,dnscdn
DOMAIN-KEYWORD,dns-cdn
DOMAIN-KEYWORD,dns.cdn

# API DNS variants
DOMAIN-KEYWORD,apidns
DOMAIN-KEYWORD,api-dns
DOMAIN-KEYWORD,api.dns
DOMAIN-KEYWORD,dnsapi
DOMAIN-KEYWORD,dns-api
DOMAIN-KEYWORD,dns.api

# WeChat
DOMAIN-KEYWORD,dns.weixin
