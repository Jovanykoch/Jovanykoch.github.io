# Loon Rule List (APPLE / iOS)
# Target Policy: DIRECT
#
# Usage (Loon):
# - Add as Remote Rule List and set policy: DIRECT
#
# Purpose:
# - Keep iOS/Apple connectivity stable (App Store / Push / iCloud)

# Captive / connectivity
DOMAIN,captive.apple.com

# Core Apple domains
DOMAIN-SUFFIX,apple.com
DOMAIN-SUFFIX,icloud.com
DOMAIN-SUFFIX,apple-dns.net

# Push / APNs
DOMAIN-SUFFIX,push.apple.com

# Common Apple service endpoints
DOMAIN-SUFFIX,apple-cloudkit.com
DOMAIN-SUFFIX,apple-mapkit.com
DOMAIN-SUFFIX,appstore.com
DOMAIN,itunes.apple.com
DOMAIN-SUFFIX,cdn-apple.com
DOMAIN-SUFFIX,icloud-content.com
DOMAIN-SUFFIX,me.com