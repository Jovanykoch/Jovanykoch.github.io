# ======== Rule Section ========
# File: mail.list
# Purpose: Route only common mail hostnames for jjc.edu (strict mode)

[Rule]

# Common mail endpoints
DOMAIN,mail.jjc.edu
DOMAIN,smtp.jjc.edu
DOMAIN,imap.jjc.edu
DOMAIN,pop.jjc.edu
DOMAIN,autodiscover.jjc.edu
DOMAIN,webmail.jjc.edu

# ======== END ========